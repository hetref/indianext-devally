generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id
  name                    String
  email                   String                   @unique
  emailVerified           Boolean                  @default(false)
  image                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  twoFactorEnabled        Boolean?                 @default(false)
  phoneNumber             String?
  banExpiresAt            DateTime?
  bannedAt                DateTime?
  isBanned                Boolean                  @default(false)
  accounts                Account[]
  createdAgreements       Agreement[]              @relation("Creator")
  receivedAgreements      Agreement[]              @relation("Receiver")
  agreementChangeRequests AgreementChangeRequest[]
  chat_message            chat_message[]
  notifications           Notification[]
  passkeys                Passkey[]
  purchases               Purchase[]
  withdrawals             Withdrawal[]
  sessions                Session[]
  ticketsAgainstMe        Ticket[]                 @relation("TicketsAgainstUser")
  raisedTickets           Ticket[]                 @relation("RaisedTickets")
  milestoneSubmissions    MilestoneSubmission[]
  twofactors              TwoFactor[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Passkey {
  id           String    @id
  name         String?
  publicKey    String
  userId       String
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime?
  aaguid       String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model Purchase {
  id                String   @id @default(cuid())
  userId            String
  amount            Float
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  status            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("purchase")
}

model Withdrawal {
  id              String   @id @default(cuid())
  userId          String
  walletAddress   String
  amountPcc       Float
  amountBaseUnits String
  txHash          String?  @unique
  status          String   @default("PENDING")
  failureReason   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@index([walletAddress])
  @@map("withdrawal")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  message    String
  type       String
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@map("notification")
}

model Agreement {
  id              String                   @id @default(cuid())
  title           String
  description     String?
  amount          Float
  status          String                   @default("DRAFT")
  currency        String                   @default("PUSD")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  creatorId       String
  receiverId      String
  projectId       Int?                     @unique
  receiverAddress String?
  transactionHash String?
  clientRefId     String?
  dueDate         DateTime?
  fundingError    String?
  creator         User                     @relation("Creator", fields: [creatorId], references: [id], onDelete: Cascade)
  receiver        User                     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  changeRequests  AgreementChangeRequest[]
  chat_message    chat_message[]
  milestones      Milestone[]
  submissions     MilestoneSubmission[]
  tickets         Ticket[]

  @@index([creatorId])
  @@index([receiverId])
  @@index([projectId])
  @@map("agreement")
}

model AgreementChangeRequest {
  id            String    @id @default(cuid())
  note          String
  createdAt     DateTime  @default(now())
  agreementId   String
  requestedById String
  agreement     Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  requestedBy   User      @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@index([requestedById])
  @@map("agreement_change_request")
}

model Ticket {
  id            String         @id @default(cuid())
  title         String
  description   String
  reason        String
  status        String         @default("OPEN")
  evidenceUrl   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  raisedById    String
  againstUserId String
  agreementId   String?
  severity      TicketSeverity @default(LOW)
  againstUser   User           @relation("TicketsAgainstUser", fields: [againstUserId], references: [id], onDelete: Cascade)
  agreement     Agreement?     @relation(fields: [agreementId], references: [id])
  raisedBy      User           @relation("RaisedTickets", fields: [raisedById], references: [id], onDelete: Cascade)

  @@index([raisedById])
  @@index([againstUserId])
  @@index([agreementId])
  @@index([status])
  @@index([severity])
  @@map("ticket")
}

model Milestone {
  id           String    @id @default(cuid())
  title        String
  description  String?
  amount       Float
  status       String    @default("PENDING")
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  agreementId  String
  order        Int       @default(0)
  paidAt       DateTime?
  payoutTxHash String?
  agreement    Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  submissions  MilestoneSubmission[]

  @@index([agreementId])
  @@map("milestone")
}

model MilestoneSubmission {
  id                     String    @id @default(cuid())
  agreementId            String
  milestoneId            String
  submittedById          String
  imageUrl               String?
  supportingLink         String?
  verificationUrl        String
  confidenceScore        Int       @default(0)
  clientDecisionRequired Boolean   @default(true)
  requirementsMet        String[]  @default([])
  requirementsMissing    String[]  @default([])
  perCriterion           Json?
  summary                String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  agreement              Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  milestone              Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  submittedBy            User      @relation(fields: [submittedById], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@index([milestoneId])
  @@index([submittedById])
  @@index([createdAt(sort: Desc)])
  @@map("milestone_submission")
}

model chat_message {
  id          String     @id
  content     String
  createdAt   DateTime   @default(now())
  senderId    String
  agreementId String?
  projectId   Int?
  agreement   Agreement? @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@index([projectId])
  @@index([senderId])
}

enum TicketSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
